app = "eterna-enforcement-worker"
primary_region = "iad"

[build]
  dockerfile = "Dockerfile"

[env]
  PORT = "8080"
  PROFILE_DIR = "/data/profiles"

[[mounts]]
  source = "profiles"
  destination = "/data"

[[services]]
  internal_port = 8080
  protocol = "tcp"

  [[services.ports]]
    handlers = ["http"]
    port = 80

  [[services.ports]]
    handlers = ["tls", "http"]
    port = 443

  [services.concurrency]
    hard_limit = 10
    soft_limit = 4

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 1024
