# ==============================================================================
# Public Frontend Variables (Safe to expose)
# ==============================================================================
# Base URL for the public-facing application
PUBLIC_APP_URL="http://localhost:5173"

# ==============================================================================
# Supabase
# ==============================================================================
# Public variables for Supabase (Frontend & Backend)
VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_URL="https://your_supabase_project_id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"

SUPABASE_URL="https://your_supabase_project_id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"

# Secret Supabase Key (Backend Only - Bypass RLS)
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# ==============================================================================
# Firecrawl (Web Scanning API)
# ==============================================================================
# Secret Key for Mendable Firecrawl
FIRECRAWL_API_KEY="your_firecrawl_api_key"

# ==============================================================================
# Google / YouTube / Lovable AI
# ==============================================================================
# Google/YouTube API Key for Video Scanning
GOOGLE_API_KEY="your_google_api_key"
YOUTUBE_API_KEY="your_youtube_api_key"

# Lovable API Key (Gemini extraction / video classification)
LOVABLE_API_KEY="your_lovable_api_key"

# Fact Checking API Key
FACT_CHECK_API_KEY="your_fact_check_api_key"

# Google Cloud Project Configuration (Vision/Translation/Speech)
GOOGLE_CLOUD_PROJECT_ID="your_google_cloud_project_id"
GOOGLE_CLOUD_STORAGE_BUCKET="your_google_cloud_storage_bucket"
GOOGLE_APPLICATION_CREDENTIALS_JSON="your_google_application_credentials_json"

# ==============================================================================
# AWS Rekognition & S3 (Face Protection & Assets)
# ==============================================================================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
AWS_REKOGNITION_BUCKET="your_aws_rekognition_bucket"

# ==============================================================================
# Veriff (KYC / Identity Verification)
# ==============================================================================
VERIFF_API_KEY="your_veriff_api_key"
VERIFF_SHARED_SECRET="your_veriff_shared_secret"
VERIFF_BASE_URL="https://stationapi.veriff.com"

# ==============================================================================
# Multimedia (MM) Quotas and Provider Configuration
# ==============================================================================
MM_MAX_VIDEO_MINUTES="60"
MM_MAX_UPLOAD_MB="500"
MM_DAILY_ANALYSIS_LIMIT="25"
MM_MONTHLY_COST_LIMIT_USD="50"
MM_EVIDENCE_RETENTION_DAYS="90"

MM_PROVIDER_VIDEO_INTELLIGENCE="stub"
MM_PROVIDER_SPEECH_TO_TEXT="stub"
MM_PROVIDER_VISION="stub"
MM_PROVIDER_TRANSLATION="stub"
MM_PROVIDER_FACT_CHECK="stub"
